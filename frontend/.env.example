VITE_TWITCH_CLIENT_ID=
VITE_TWITCH_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_PROXY_URL=http://localhost:8080

# Optional - enables ?demo=1 read-only mode using a cached Twitch token.
# The demo token is baked into the JS bundle (VITE_* vars are public) -
# only use a token with read-only scopes.
VITE_DEMO_USER_ID=
VITE_DEMO_TOKEN=
