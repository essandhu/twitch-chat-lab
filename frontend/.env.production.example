# Production env template for Vercel.
# These are set in the Vercel dashboard (Project Settings -> Environment Variables).
# Do NOT commit real values.

# From dev.twitch.tv/console (same app used in dev, with prod redirect URI added).
VITE_TWITCH_CLIENT_ID=

# Production callback: https://<vercel-app>.vercel.app/auth/callback
VITE_TWITCH_REDIRECT_URI=

# Go proxy on Fly.io: wss://<fly-app>.fly.dev
VITE_PROXY_URL=

# Optional read-only demo (?demo=1 URL).
# The token is baked into the bundle; only use read-only scopes.
VITE_DEMO_USER_ID=
VITE_DEMO_TOKEN=
